{
  "name": "pet_shop",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "db:migrate:make": "kysely migrate:make new_migration",
    "db:migrate:latest": "kysely migrate:latest",
    "db:codegen": "kysely-codegen --url db.sqlite --out-file src/lib/db-types.ts",
    "db:seed:make": "kysely seed:make new_seed",
    "db:seed:run": "kysely seed:run"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.2.0",
    "kysely": "^0.28.5",
    "next": "^15.5.7",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "resend": "^6.6.0",
    "validator": "^13.15.23"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/validator": "^13.15.10",
    "eslint": "^9",
    "eslint-config-next": "15.5.2",
    "kysely-codegen": "^0.19.0",
    "kysely-ctl": "^0.19.0",
    "tsx": "^4.20.5",
    "typescript": "^5"
  },
  "overrides": {
    "kysely-codegen": {
      "better-sqlite3": "^12.2.0"
    }
  }
}
